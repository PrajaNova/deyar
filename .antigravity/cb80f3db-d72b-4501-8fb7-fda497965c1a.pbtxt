      replacement_content: "import React, { useState, useMemo } from \'react\';\nimport { Calendar, Users, Clock, Coffee, Sparkles, Check, CheckCircle, ShieldAlert, Award, ChevronRight } from \'lucide-react\';\nimport { Reservation } from \'../types\';\n\nexport const ReservationSection: React.FC = () => {\n  // Wizard active step\n  const [activeStep, setActiveStep] = useState<number>(1);\n  \n  // Reservation Form State\n  const [formData, setFormData] = useState({\n    guests: 2,\n    date: new Date().toISOString().split(\'T\')[0],\n    time: \'18:00\',\n    selectedTableId: \'\',\n    name: \'\',\n    email: \'\',\n    phone: \'\',\n    specialRequests: \'\'\n  });\n\n  // Table structures inside the cozy mountain cabin\n  const CABIN_TABLES = [\n    { id: \'t1\', name: \'Altar Hearth Fireplace Bench\', capacity: 4, type: \'hearth\', description: \'Placed directly beside the stone woodstove\', status: \'available\' },\n    { id: \'t2\', name: \'Deodar Crest Window Desk\', capacity: 2, type: \'window\', description: \'Overlooks the distant misty deodar groves\', status: \'available\' },\n    { id: \'t3\', name: \'Library Reading Alcove\', capacity: 1, type: \'wood\', description: \'Cozy leather seat flanked by folklore logs\', status: \'available\' },\n    { id: \'t4\', name: \'Central Round Oak Hearth\', capacity: 6, type: \'hearth\', description: \'Heavy timber round table, ideal for gatherings\', status: \'reserved\' },\n    { id: \'t5\', name: \'Forest Spruce Skydeck Table\', capacity: 4, type: \'deck\', description: \'Semi-outdoor deck with cold pine wind-breeze\', status: \'available\' },\n    { id: \'t6\', name: \'The Bear Den Secret Bench\', capacity: 2, type: \'window\', description: \'Secluded curtained timber alcove\', status: \'available\' },\n    { id: \'t7\', name: \'Hearth-Bar Stool Alpha\', capacity: 1, type: \'stool\', description: \'Tavern stool overlooking espresso draft taps\', status: \'available\' },\n    { id: \'t8\', name: \'Hearth-Bar Stool Beta\', capacity: 1, type: \'stool\', description: \'Tavern stool overlooking espresso draft taps\', status: \'reserved\' }\n  ];\n\n  // Random booking ticket helper\n  const confirmedReservationId = useMemo(() => {\n    return \'DYR-\' + Math.floor(100000 + Math.random() * 900000);\n  }, [activeStep === 4]);\n\n  // Selected Table Item\n  const activeTable = useMemo(() => {\n    return CABIN_TABLES.find(t => t.id === formData.selectedTableId);\n  }, [formData.selectedTableId]);\n\n  // Handle first validation step\n  const handleNextToSeating = () => {\n    if (!formData.date || !formData.time) return;\n    setActiveStep(2);\n  };\n\n  // Handle seating option selection\n  const handleSelectTable = (tableId: string) => {\n    const table = CABIN_TABLES.find(t => t.id === tableId);\n    if (table && table.status === \'available\') {\n      setFormData(prev => ({ ...prev, selectedTableId: tableId }));\n    }\n  };\n\n  // Handle seating step forward\n  const handleNextToForm = () => {\n    if (!formData.selectedTableId) return;\n    setActiveStep(3);\n  };\n\n  // Finalize reservation submission\n  const handleFinalizeBooking = (e: React.FormEvent) => {\n    e.preventDefault();\n    if (!formData.name || !formData.email || !formData.phone) return;\n    \n    // Move to visual ticket stub phase\n    setActiveStep(4);\n  };\n\n  // Start a fresh reservation\n  const handleResetBooking = () => {\n    setFormData({\n      guests: 2,\n      date: new Date().toISOString().split(\'T\')[0],\n      time: \'18:00\',\n      selectedTableId: \'\',\n      name: \'\',\n      email: \'\',\n      phone: \'\',\n      specialRequests: \'\'\n    });\n    setActiveStep(1);\n  };\n\n  return (\n    <section className=\"bg-brand-cream-light py-12 px-4 sm:px-6 lg:px-8 w-full min-h-[85vh] text-brand-espresso\">\n      <div className=\"max-w-4xl mx-auto space-y-12\">\n        \n        {/* Page Title Header */}\n        <div className=\"text-center max-w-2xl mx-auto space-y-3\">\n          <span className=\"font-display text-xs uppercase tracking-[0.25em] text-brand-rust block\">VISITING RESERVATIONS</span>\n          <h1 className=\"font-serif text-4xl font-bold tracking-tight\">Hearth Booking System</h1>\n          <p className=\"font-sans text-xs md:text-sm text-brand-cocoa leading-relaxed font-light\">\n            Due to our small room sizes and slow-cooking wood stoves, we recommend securing your cozy hearth bench 1-3 mountain cycles in advance.\n          </p>\n          <div className=\"h-0.5 w-16 bg-brand-rust mx-auto mt-4\" />\n        </div>\n\n        {/* Wizard Progression markers */}\n        <div className=\"max-w-xl mx-auto flex items-center justify-between border-b border-brand-cocoa/20 pb-4 text-2xs uppercase tracking-widest font-display text-brand-cocoa font-semibold\">\n          <span className={`${activeStep >= 1 ? \'text-brand-rust\' : \'\'}`}>01 Slot Select</span>\n          <ChevronRight className=\"w-3.5 h-3.5\" />\n          <span className={`${activeStep >= 2 ? \'text-brand-rust\' : \'\'}`}>02 Seat Map</span>\n          <ChevronRight className=\"w-3.5 h-3.5\" />\n          <span className={`${activeStep >= 3 ? \'text-brand-rust\' : \'\'}`}>03 Lodge Credentials</span>\n          <ChevronRight className=\"w-3.5 h-3.5\" />\n          <span className={`${activeStep >= 4 ? \'text-brand-rust\' : \'\'}`}>04 Ticket Stub</span>\n        </div>\n\n        {/* Dynamic Wizard Steps Switchboard */}\n        <div className=\"bg-brand-cream rounded-3xl p-6 md:p-10 border border-brand-cocoa/15 shadow-sm\">\n          \n          {/* STEP 1: PARTY SIZE, DATE, AND TIME INPUT */}\n          {activeStep === 1 && (\n            <div className=\"space-y-8 animate-fade-in\">\n              <div className=\"space-y-1.5\">\n                <h3 className=\"font-serif text-2xl font-bold\">Select Date & Party Size</h3>\n                <p className=\"font-sans text-xs text-brand-cocoa\">Tell us when you will be hiking in and how many travelers will join.</p>\n              </div>\n\n              <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6\">\n                \n                {/* Party size counter picker */}\n                <div className=\"space-y-2 bg-brand-cream-light p-4 rounded-2xl border\">\n                  <label htmlFor=\"res-guests-select\" className=\"flex items-center gap-2 font-display text-xs uppercase tracking-wider font-semibold text-brand-espresso\">\n                    <Users className=\"w-4 h-4 text-brand-rust\" />\n                    How many travelers?\n                  </label>\n                  <p className=\"text-[10px] font-sans text-brand-cocoa mb-3\">Include toddler hiking packs if any</p>\n                  \n                  <div className=\"flex items-center justify-between border border-brand-cocoa/30 rounded-full px-3 py-1 bg-brand-cream max-w-sm mx-auto\">\n                    <button\n                      disabled={formData.guests <= 1}\n                      onClick={() => setFormData({ ...formData, guests: formData.guests - 1 })}\n                      className=\"w-8 h-8 rounded-full bg-brand-cream hover:bg-brand-cocoa/10 flex items-center justify-center font-sans font-bold cursor-pointer disabled:opacity-40\"\n                    >\n                      -\n                    </button>\n                    <span className=\"font-display font-semibold text-sm w-4 text-center\">{formData.guests}</span>\n                    <button\n                      disabled={formData.guests >= 8}\n                      onClick={() => setFormData({ ...formData, guests: formData.guests + 1 })}\n                      className=\"w-8 h-8 rounded-full bg-brand-cream hover:bg-brand-cocoa/10 flex items-center justify-center font-sans font-bold cursor-pointer disabled:opacity-40\"\n                    >\n                      +\n                    </button>\n                  </div>\n                </div>\n\n                {/* Date Picker */}\n                <div className=\"space-y-2 bg-brand-cream-light p-4 rounded-2xl border\">\n                  <label htmlFor=\"res-date-select\" className=\"flex items-center gap-2 font-display text-xs uppercase tracking-wider font-semibold text-brand-espresso\">\n                    <Calendar className=\"w-4 h-4 text-brand-pine\" />\n                    Preferred Cycle Date\n                  </label>\n                  <p className=\"text-[10px] font-sans text-brand-cocoa mb-3\">Calendar date for reservation bookings</p>\n                  <input\n                    id=\"res-date-select\"\n                    type=\"date\"\n                    required\n                    min={new Date().toISOString().split(\'T\')[0]}\n                    value={formData.date}\n                    onChange={(e) => setFormData({ ...formData, date: e.target.value })}\n                    className=\"w-full px-3 py-2.5 rounded-full bg-brand-cream border border-brand-cocoa/30 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs text-center cursor-pointer\"\n                  />\n                </div>\n\n                {/* Time Picker */}\n                <div className=\"space-y-2 bg-brand-cream-light p-4 rounded-2xl border\">\n                  <label htmlFor=\"res-time-select\" className=\"flex items-center gap-2 font-display text-xs uppercase tracking-wider font-semibold text-brand-espresso\">\n                    <Clock className=\"w-4 h-4 text-brand-gold\" />\n                    Hearth Arrival Time\n                  </label>\n                  <p className=\"text-[10px] font-sans text-brand-cocoa mb-3\">Time slot between 7:30 AM & 8:30 PM</p>\n                  <select\n                    id=\"res-time-select\"\n                    value={formData.time}\n                    onChange={(e) => setFormData({ ...formData, time: e.target.value })}\n                    className=\"w-full px-3 py-2.5 rounded-full bg-brand-cream border border-brand-cocoa/30 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs text-center cursor-pointer\"\n                  >\n                    <option value=\"08:00\">08:00 AM (Sunrise Steep)</option>\n                    <option value=\"10:00\">10:00 AM (Orchard Morning)</option>\n                    <option value=\"12:00\">12:00 PM (Noon Timber Broths)</option>\n                    <option value=\"14:00\">02:00 PM (Post-Trek Cider)</option>\n                    <option value=\"16:00\">04:00 PM (Afternoon Pine Sage)</option>\n                    <option value=\"18:00\">06:00 PM (Sunset Fireside Lounge)</option>\n                    <option value=\"20:00\">08:00 PM (Late-Hearth Storytelling)</option>\n                  </select>\n                </div>\n\n              </div>\n\n              <div className=\"pt-4 border-t border-brand-cocoa/10 flex justify-end\">\n                <button\n                  onClick={handleNextToSeating}\n                  className=\"px-6 py-3.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow cursor-pointer flex items-center gap-2\"\n                >\n                  Proceed to Seating Blueprint\n                  <ChevronRight className=\"w-4 h-4\" />\n                </button>\n              </div>\n            </div>\n          )}\n\n          {/* STEP 2: TABLE MAP SELECTION */}\n          {activeStep === 2 && (\n            <div className=\"space-y-8 animate-fade-in col-span-full\">\n              <div className=\"flex flex-col sm:flex-row sm:justify-between sm:items-start gap-4\">\n                <div className=\"space-y-1.5\">\n                  <h3 className=\"font-serif text-2xl font-bold\">Lodge Seating Blueprint</h3>\n                  <p className=\"font-sans text-xs text-brand-cocoa\">Click on an available layout to secure your nook. Table capacities are listed.</p>\n                </div>\n                \n                {/* Visual Legend */}\n                <div className=\"flex gap-4 text-sans text-[10px] text-brand-espresso/80 font-medium\">\n                  <span className=\"flex items-center gap-1.5\"><span className=\"h-3 w-3 bg-brand-cream-light border border-brand-cocoa/20 rounded-md inline-block\" /> Available</span>\n                  <span className=\"flex items-center gap-1.5\"><span className=\"h-3 w-3 bg-brand-rust rounded-md inline-block\" /> Selected</span>\n                  <span className=\"flex items-center gap-1.5\"><span className=\"h-3 w-3 bg-brand-dark/25 rounded-md inline-block\" /> Reserved</span>\n                </div>\n              </div>\n\n              {/* Seating Layout Blueprint Grid */}\n              <div className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">\n                {CABIN_TABLES.map((table) => {\n                  const isSelected = formData.selectedTableId === table.id;\n                  const isReserved = table.status === \'reserved\';\n                  \n                  return (\n                    <button\n                      key={table.id}\n                      disabled={isReserved}\n                      onClick={() => handleSelectTable(table.id)}\n                      className={`text-left p-4 rounded-2xl border transition-all pointer-events-auto cursor-pointer ${\n                        isReserved \n                          ? \'bg-brand-dark/5 opacity-60 pointer-events-none border-brand-cocoa/10\'\n                          : isSelected\n                            ? \'bg-brand-rust/10 border-brand-rust shadow-md ring-1 ring-brand-rust\'\n                            : \'bg-brand-cream-light border-brand-cocoa/20 hover:border-brand-espresso/50\'\n                      }`}\n                    >\n                      <div className=\"flex items-center justify-between gap-2\">\n                        <div className=\"space-y-1\">\n                          <span className=\"font-serif text-sm font-semibold block text-brand-espresso\">\n                            {table.name}\n                          </span>\n                          <span className=\"block text-[10.5px] font-sans text-brand-cocoa font-light leading-snug\">\n                            {table.description}\n                          </span>\n                        </div>\n                        \n                        {/* Status Marker Pill */}\n                        <div className=\"shrink-0 text-right\">\n                          <span className={`inline-block px-2 py-0.5 rounded-full font-display text-[8px] uppercase tracking-widest font-semibold ${\n                            isReserved \n                              ? \'bg-brand-dark/20 text-brand-dark/60\'\n                              : isSelected\n                                ? \'bg-brand-rust text-brand-cream\'\n                                : \'bg-brand-pine/10 text-brand-pine\'\n                          }`}>\n                            {isReserved ? \'Reserved\' : isSelected ? \'Chosen\' : `Cap: ${table.capacity}`}\n                          </span>\n                        </div>\n                      </div>\n                    </button>\n                  );\n                })}\n              </div>\n\n              {/* Seating confirmation drawer */}\n              <div className=\"pt-6 border-t border-brand-cocoa/10 flex flex-col sm:flex-row justify-between items-center gap-4\">\n                <div className=\"text-center sm:text-left text-xs font-sans text-brand-cocoa font-light\">\n                  {formData.selectedTableId ? (\n                    <p>Selected nook: <span className=\"font-semibold text-brand-rust font-serif text-sm\">{activeTable?.name}</span></p>\n                  ) : (\n                    <p className=\"text-rose-400 font-medium\">Please tap a seat blueprint table above to select it.</p>\n                  )}\n                </div>\n                \n                <div className=\"flex gap-3\">\n                  <button\n                    onClick={() => setActiveStep(1)}\n                    className=\"px-5 py-3 border border-brand-cocoa/40 text-brand-espresso hover:bg-brand-cocoa/5 rounded-full font-display text-2xs uppercase tracking-widest font-semibold\"\n                  >\n                    Back to Date\n                  </button>\n                  <button\n                    disabled={!formData.selectedTableId}\n                    onClick={handleNextToForm}\n                    className=\"px-6 py-3 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow cursor-pointer disabled:opacity-40\"\n                  >\n                    Enter Credentials\n                  </button>\n                </div>\n              </div>\n            </div>\n          )}\n\n          {/* STEP 3: CONTACT INFORMATION FORM */}\n          {activeStep === 3 && (\n            <form onSubmit={handleFinalizeBooking} className=\"space-y-6 animate-fade-in pointer-events-auto\">\n              <div className=\"space-y-1.5\">\n                <h3 className=\"font-serif text-2xl font-bold\">Lodge Credentials</h3>\n                <p className=\"font-sans text-xs text-brand-cocoa\">Fill in your hiker notes and name so we can stamp your booking ticket.</p>\n              </div>\n\n              {/* Seating summary alert box */}\n              <div className=\"px-4 py-3.5 bg-brand-pine/10 border border-brand-pine/25 rounded-xl font-sans text-xs flex items-start gap-3\">\n                <Award className=\"w-5 h-5 text-brand-pine shrink-0 mt-0.5\" strokeWidth={1.5} />\n                <div>\n                  <h4 className=\"font-serif font-bold text-brand-pine leading-none\">Draft Reservation Selections Locked</h4>\n                  <p className=\"text-brand-espresso/80 font-light mt-1.5\">\n                    Table: <span className=\"font-medium font-serif\">{activeTable?.name}</span> \342\200\242 Setup for <span className=\"font-semibold\">{formData.guests} hikers</span> on <span className=\"font-semibold\">{formData.date}</span> at <span className=\"font-semibold\">{formData.time}</span>.\n                  </p>\n                </div>\n              </div>\n\n              <div className=\"grid grid-cols-1 sm:grid-cols-3 gap-5\">\n                <div className=\"space-y-2 col-span-full sm:col-span-1\">\n                  <label htmlFor=\"res-user-name\" className=\"bloch font-display text-[9.5px] uppercase tracking-widest font-semibold\">Your Full Name</label>\n                  <input\n                    id=\"res-user-name\"\n                    required\n                    type=\"text\"\n                    placeholder=\"e.g. Priyanjali Sen\"\n                    value={formData.name}\n                    onChange={(e) => setFormData({ ...formData, name: e.target.value })}\n                    className=\"w-full px-4 py-3 rounded-xl bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  />\n                </div>\n\n                <div className=\"space-y-2 col-span-full sm:col-span-1\">\n                  <label htmlFor=\"res-user-email\" className=\"block font-display text-[9.5px] uppercase tracking-widest font-semibold\">Email Mailbox</label>\n                  <input\n                    id=\"res-user-email\"\n                    required\n                    type=\"email\"\n                    placeholder=\"e.g. priya@senhikes.in\"\n                    value={formData.email}\n                    onChange={(e) => setFormData({ ...formData, email: e.target.value })}\n                    className=\"w-full px-4 py-3 rounded-xl bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  />\n                </div>\n\n                <div className=\"space-y-2 col-span-full sm:col-span-1\">\n                  <label id=\"res-phone-label\" htmlFor=\"res-phone\" className=\"block font-display text-[9.5px] uppercase tracking-widest font-semibold\">Mobile Trail Phone</label>\n                  <input\n                    id=\"res-phone\"\n                    required\n                    type=\"tel\"\n                    placeholder=\"e.g. +91 98160 54321\"\n                    value={formData.phone}\n                    onChange={(e) => setFormData({ ...formData, phone: e.target.value })}\n                    className=\"w-full px-4 py-3 rounded-xl bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-2\">\n                <label id=\"res-requests-label\" htmlFor=\"res-requests\" className=\"block font-display text-[9.5px] uppercase tracking-widest font-semibold\">Special Dietary or Seating Requests (Optional)</label>\n                <textarea\n                  id=\"res-requests\"\n                  placeholder=\"Need high-chairs, bringing pets, or requesting special floral tea steep packs?\"\n                  rows={3}\n                  value={formData.specialRequests}\n                  onChange={(e) => setFormData({ ...formData, specialRequests: e.target.value })}\n                  className=\"w-full p-4 rounded-xl bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                />\n              </div>\n\n              {/* Submit Buttons */}\n              <div className=\"grid grid-cols-2 gap-4 pt-4 border-t border-brand-cocoa/10\">\n                <button\n                  type=\"button\"\n                  onClick={() => setActiveStep(2)}\n                  className=\"px-5 py-3.5 border border-brand-cocoa/40 text-brand-espresso hover:bg-brand-cocoa/5 rounded-full font-display text-2xs uppercase tracking-widest font-semibold\"\n                >\n                  Back to Seats\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"px-6 py-3.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow cursor-pointer text-center\"\n                >\n                  Generate Stamped Booking Ticket\n                </button>\n              </div>\n            </form>\n          )}\n\n          {/* STEP 4: GORGEOUS EXCLUSIVE PRINTABLE WOOD-STAMPED BOOKING TICKET */}\n          {activeStep === 4 && (\n            <div className=\"space-y-8 animate-fade-in text-center flex flex-col items-center\">\n              \n              <div className=\"space-y-1\">\n                <div className=\"w-12 h-12 rounded-full bg-brand-pine/10 border border-brand-pine/30 flex items-center justify-center mx-auto mb-2 text-brand-pine animate-bounce\">\n                  <CheckCircle className=\"w-6 h-6\" />\n                </div>\n                <h3 className=\"font-serif text-2xl font-bold text-brand-pine\">Reservation Confirmed!</h3>\n                <p className=\"font-sans text-xs text-brand-cocoa font-light\">Your mountain lodge nook is successfully secured.</p>\n              </div>\n\n              {/* Elegant design mockup ticket wrapper */}\n              <div className=\"w-full max-w-sm bg-brand-cream-light border border-brand-cocoa/30 p-6 rounded-2xl relative shadow-md font-sans text-left border-dashed border-2\">\n                \n                {/* Visual half circles depicting tears at top & bottom edge */}\n                <span className=\"absolute -left-3 top-1/2 -mt-3 h-6 w-6 rounded-full bg-brand-cream border-r border-brand-cocoa/30 pointer-events-none\" />\n                <span className=\"absolute -right-3 top-1/2 -mt-3 h-6 w-6 rounded-full bg-brand-cream border-l border-brand-cocoa/30 pointer-events-none\" />\n\n                {/* Ticket Header */}\n                <div className=\"text-center pb-4 border-b border-brand-cocoa/30\">\n                  <span className=\"font-serif text-xl font-bold tracking-wider block text-brand-espresso\">DEYAR HEARTH</span>\n                  <span className=\"font-display text-[8.5px] uppercase tracking-[0.25em] text-brand-rust block mt-1\">HIMACHAL LODGE PASS STAMP</span>\n                </div>\n\n                {/* Ticket Details Body */}\n                <div className=\"py-5 space-y-3 font-display uppercase tracking-wider text-2xs text-brand-espresso border-b border-brand-cocoa/30\">\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">HIKER RESERVATION NO.</span>\n                    <span className=\"font-semibold text-brand-rust text-right select-all\">{confirmedReservationId}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">Primary Hiker</span>\n                    <span className=\"font-serif font-semibold text-right text-sm\">{formData.name}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">TRAIL DATE</span>\n                    <span className=\"font-semibold text-right\">{formData.date}</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">HEARTHarrival slot</span>\n                    <span className=\"font-semibold text-right\">{formData.time} PM</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">PARTY SIZE</span>\n                    <span className=\"font-semibold text-right\">{formData.guests} PERSONS</span>\n                  </div>\n                  <div className=\"flex justify-between\">\n                    <span className=\"text-brand-cocoa\">SECURED LODGE NOOK</span>\n                    <span className=\"font-serif font-semibold text-right text-brand-pine break-all max-w-[160px] leading-tight\">{activeTable?.name}</span>\n                  </div>\n                </div>\n\n                {/* Confirming Note stamp */}\n                <div className=\"pt-4 pb-2 text-center\">\n                  <span className=\"text-[10px] font-sans text-brand-cocoa font-light italic text-center block\">\n                    We host your table for exactly 20 minutes from slated arrival cycle.\n                  </span>\n                  \n                  {/* Decorative CSS Barcode stamp representing traditional aesthetic */}\n                  <div className=\"mt-4 flex flex-col items-center gap-1\">\n                    <div className=\"flex gap-0.5 justify-center opacity-65\">\n                      <span className=\"h-7 w-0.5 bg-brand-espresso\" />\n                      <span className=\"h-7 w-1 bg-brand-espresso\" />\n                      <span className=\"h-7 w-1.5 bg-brand-espresso\" />\n                      <span className=\"h-7 w-0.5 bg-brand-espresso\" />\n                      <span className=\"h-7 w-2 bg-brand-espresso\" />\n                      <span className=\"h-7 w-0.5 bg-brand-espresso\" />\n                      <span className=\"h-7 w-1 bg-brand-espresso\" />\n                      <span className=\"h-7 w-1.5 bg-brand-espresso\" />\n                      <span className=\"h-7 w-0.5 bg-brand-espresso\" />\n                    </div>\n                    <span className=\"text-[9px] font-mono uppercase tracking-[0.3em] text-brand-cocoa select-none\">STAMP VALID</span>\n                  </div>\n\n                </div>\n\n       