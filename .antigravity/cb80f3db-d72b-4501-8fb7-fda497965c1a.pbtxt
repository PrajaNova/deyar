        }
        lines {
          text: "    role: \'Local Writer & Regular\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'Deyar is not just a cafe, its a retreat. The smell of deodar-smoked espresso immediately transports me to Himachali childhood log cabins. The Siddu Walnut roll is absolutely spectacular.\',"
