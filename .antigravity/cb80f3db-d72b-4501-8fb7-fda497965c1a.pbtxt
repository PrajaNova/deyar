  file_change {
    absolute_path_uri: "file:///src/components/CartDrawer.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useMemo } from \'react\';\nimport { X, Trash2, ShoppingBag, MapPin, Bike, Check, Stepper, Coffee, ChevronRight, Compass } from \'lucide-react\';\nimport { CartItem } from \'../types\';\n\ninterface CartDrawerProps {\n  isOpen: boolean;\n  onClose: () => void;\n  cartItems: CartItem[];\n  onUpdateQty: (cartItemId: string, newQty: number) => void;\n  onRemoveItem: (cartItemId: string) => void;\n  onClearCart: () => void;\n}\n\nexport const CartDrawer: React.FC<CartDrawerProps> = ({\n  isOpen,\n  onClose,\n  cartItems,\n  onUpdateQty,\n  onRemoveItem,\n  onClearCart\n}) => {\n  // Checkout Multi-Phase State\n  // 1 = view cart, 2 = select fulfillment, 3 = confirmation tracker\n  const [checkoutStep, setCheckoutStep] = useState<number>(1);\n  const [fulfillmentType, setFulfillmentType] = useState<\'delivery\' | \'pickup\'>(\'pickup\');\n  const [shippingDetails, setShippingDetails] = useState({ name: \'\', address: \'\', phone: \'\' });\n\n  // Option price modifier helper\n  const getItemPriceModifier = (selectedOptions: { [key: string]: string }) => {\n    let extra = 0;\n    Object.keys(selectedOptions).forEach((key) => {\n      const val = selectedOptions[key];\n      if (val.includes(\'+ $\')) {\n        const parts = val.split(\'+ $\');\n        if (parts.length > 1) {\n          const amount = parseFloat(parts[1]);\n          if (!isNaN(amount)) {\n            extra += amount;\n          }\n        }\n      }\n    });\n    return extra;\n  };\n\n  // Subtotal Calculation\n  const subtotal = useMemo(() => {\n    return cartItems.reduce((acc, item) => {\n      const extra = getItemPriceModifier(item.selectedOptions);\n      return acc + (item.menuItem.price + extra) * item.quantity;\n    }, 0);\n  }, [cartItems]);\n\n  const tax = subtotal * 0.05; // 5% state tax\n  const packagingFee = subtotal > 0 ? 1.50 : 0; // packaging fee for eco-friendly fibers\n  const total = subtotal + tax + packagingFee;\n\n  // Checkout submit simulation\n  const handleProceedToPayment = (e: React.FormEvent) => {\n    e.preventDefault();\n    setCheckoutStep(3);\n  };\n\n  // Close and reset Checkout view\n  const handleDismissCart = () => {\n    onClose();\n    // Keep short cooling state so sliding is clean\n    setTimeout(() => {\n      setCheckoutStep(1);\n    }, 500);\n  };\n\n  if (!isOpen) return null;\n\n  return (\n    <div className=\"fixed inset-0 z-50 overflow-hidden font-sans\">\n      \n      {/* Outer ambient darkness backdrop clickable to exit */}\n      <div \n        className=\"absolute inset-0 bg-brand-dark/60 backdrop-blur-xs transition-opacity animate-fade-in cursor-pointer\"\n        onClick={handleDismissCart}\n      />\n\n      <div className=\"absolute inset-y-0 right-0 max-w-full flex pl-10 pointer-events-none\">\n        <div className=\"w-screen max-w-md pointer-events-auto h-full bg-brand-cream-light border-l border-brand-cocoa/20 flex flex-col shadow-2xl relative\">\n          \n          {/* Header */}\n          <div className=\"px-6 py-5 bg-brand-cream border-b border-brand-cocoa/20 shrink-0 flex items-center justify-between\">\n            <div className=\"flex items-center gap-2\">\n              <ShoppingBag className=\"w-5 h-5 text-brand-rust\" />\n              <h2 className=\"font-serif text-xl font-bold text-brand-espresso\">Deyar Hearth Order</h2>\n            </div>\n            \n            <button\n              onClick={handleDismissCart}\n              className=\"p-1.5 rounded-full hover:bg-brand-cocoa/10 text-brand-espresso cursor-pointer\"\n              aria-label=\"Close cart side panel\"\n            >\n              <X className=\"w-5 h-5\" />\n            </button>\n          </div>\n\n          {/* CHECKOUT FLOW SWITCHBOARD VIEWPORT */}\n          \n          {/* PHASE 1: VIEW/MANAGE CART ROWS */}\n          {checkoutStep === 1 && (\n            <>\n              {cartItems.length === 0 ? (\n                <div className=\"flex-1 flex flex-col items-center justify-center p-6 text-center space-y-4\">\n                  <div className=\"w-16 h-16 rounded-full bg-brand-cream border flex items-center justify-center\">\n                    <Coffee className=\"w-8 h-8 text-brand-cocoa/40\" />\n                  </div>\n                  <h3 className=\"font-serif text-lg font-bold\">Your Order Bag is Empty</h3>\n                  <p className=\"text-xs text-brand-cocoa max-w-xs font-light leading-relaxed\">\n                    Browse our wild-infused brew list, click details, and add some heartwarming pastries to get started.\n                  </p>\n                  <button\n                    onClick={onClose}\n                    className=\"px-5 py-2.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold cursor-pointer\"\n                  >\n                    Browse Cozy Menu\n                  </button>\n                </div>\n              ) : (\n                <>\n                  {/* Cart List */}\n                  <div className=\"flex-1 overflow-y-auto px-6 py-4 space-y-4 subtle-scroll\">\n                    {cartItems.map((item) => {\n                      const modPrice = item.menuItem.price + getItemPriceModifier(item.selectedOptions);\n                      return (\n                        <div \n                          key={item.id} \n                          className=\"flex items-start gap-4 p-3 bg-brand-cream rounded-2xl border border-brand-cocoa/10 animate-fade-in\"\n                        >\n                          <img \n                            src={item.menuItem.image} \n                            alt={item.menuItem.name} \n                            className=\"w-16 h-16 object-cover rounded-xl shrink-0\"\n                          />\n                          \n                          <div className=\"flex-1 space-y-1\">\n                            <div className=\"flex justify-between items-start gap-1\">\n                              <h4 className=\"font-serif text-sm font-semibold text-brand-espresso leading-snug\">\n                                {item.menuItem.name}\n                              </h4>\n                              <span className=\"font-display text-xs font-semibold text-brand-rust shrink-0\">\n                                ${(modPrice * item.quantity).toFixed(2)}\n                              </span>\n                            </div>\n\n                            {/* Item customizations listed visually */}\n                            {Object.keys(item.selectedOptions).length > 0 && (\n                              <p className=\"text-[10px] font-sans text-brand-cocoa font-light leading-relaxed flex flex-wrap gap-x-2\">\n                                {Object.keys(item.selectedOptions).map((k) => (\n                                  <span key={k}><b>{k}:</b> {item.selectedOptions[k]}</span>\n                                ))}\n                              </p>\n                            )}\n\n                            {/* Notes */}\n                            {item.notes && (\n                              <p className=\"text-[10px] font-mono italic text-brand-rust/85 bg-brand-cream-light p-1 rounded mt-1\">\n                                Note: \"{item.notes}\"\n                              </p>\n                            )}\n\n                            {/* Counter or Trash Action wrapper */}\n                            <div className=\"flex items-center justify-between pt-1.5 border-t border-brand-cocoa/5 mt-1.5\">\n                              <div className=\"flex items-center gap-2.5 border rounded-full px-2 py-0.5 bg-brand-cream-light\">\n                                <button\n                                  disabled={item.quantity <= 1}\n                                  onClick={() => onUpdateQty(item.id, item.quantity - 1)}\n                                  className=\"text-xs transition-colors p-1 disabled:opacity-45\"\n                                >\n                                  -\n                                </button>\n                                <span className=\"font-display text-xs font-semibold\">{item.quantity}</span>\n                                <button\n                                  onClick={() => onUpdateQty(item.id, item.quantity + 1)}\n                                  className=\"text-xs transition-colors p-1\"\n                                >\n                                  +\n                                </button>\n                              </div>\n\n                              <button\n                                onClick={() => onRemoveItem(item.id)}\n                                className=\"text-brand-cocoa/60 hover:text-rose-500 p-1 rounded-full hover:bg-brand-cocoa/5 transition-colors\"\n                                aria-label=\"Remove item\"\n                              >\n                                <Trash2 className=\"w-3.5 h-3.5\" />\n                              </button>\n                            </div>\n\n                          </div>\n                        </div>\n                      );\n                    })}\n                  </div>\n\n                  {/* Calculations & Checkout Button Footer */}\n                  <div className=\"p-6 bg-brand-cream border-t border-brand-cocoa/20 space-y-4 shrink-0\">\n                    <div className=\"space-y-2 text-xs font-display uppercase tracking-widest text-brand-espresso\">\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-brand-cocoa text-[10px]\">Subtotal Price</span>\n                        <span className=\"font-semibold\">${subtotal.toFixed(2)}</span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-brand-cocoa text-[10px]\">Himalayan State Tax (5%)</span>\n                        <span className=\"font-semibold\">${tax.toFixed(2)}</span>\n                      </div>\n                      <div className=\"flex justify-between\">\n                        <span className=\"text-brand-cocoa text-[10px]\">Hearth Bio-Packaging</span>\n                        <span className=\"font-semibold\">${packagingFee.toFixed(2)}</span>\n                      </div>\n                      <div className=\"flex justify-between text-sm pt-2 border-t border-brand-cocoa/20 text-brand-rust\">\n                        <span className=\"font-bold\">Grand Total Amount</span>\n                        <span className=\"font-bold\">${total.toFixed(2)}</span>\n                      </div>\n                    </div>\n\n                    <div className=\"pt-2 flex flex-col gap-2\">\n                      <button\n                        onClick={() => setCheckoutStep(2)}\n                        className=\"w-full py-4 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-[0.2em] font-semibold transition-all duration-300 shadow cursor-pointer text-center\"\n                      >\n                        Proceed to Hearth checkout\n                      </button>\n                      <button\n                        onClick={onClearCart}\n                        className=\"text-center font-display text-[9.5px] uppercase tracking-widest text-brand-cocoa/75 hover:text-rose-500 pt-1\"\n                      >\n                        Empty Order Bag\n                      </button>\n                    </div>\n                  </div>\n                </>\n              )}\n            </>\n          )}\n\n          {/* PHASE 2: SELECT FULFILLMENT METHOD (PICKUP VS EXTERNAL LINKED COURIERS) */}\n          {checkoutStep === 2 && (\n            <form onSubmit={handleProceedToPayment} className=\"flex-1 flex flex-col justify-between h-full animate-fade-in pointer-events-auto\">\n              \n              <div className=\"p-6 space-y-6 overflow-y-auto subtle-scroll flex-1\">\n                <div className=\"space-y-1.5\">\n                  <h3 className=\"font-serif text-lg font-bold\">Fulfillment Modes</h3>\n                  <p className=\"text-xs text-brand-cocoa font-light\">Choose self-pickup or link directly to Himachal instant couriers.</p>\n                </div>\n\n                {/* Selective Segment selector */}\n                <div className=\"grid grid-cols-2 gap-2 bg-brand-cream p-1.5 rounded-full border border-brand-cocoa/20\">\n                  <button\n                    type=\"button\"\n                    onClick={() => setFulfillmentType(\'pickup\')}\n                    className={`py-2 rounded-full font-display text-[10px] uppercase tracking-widest font-semibold transition-all cursor-pointer ${\n                      fulfillmentType === \'pickup\'\n                        ? \'bg-brand-espresso text-brand-cream shadow-sm\'\n                        : \'text-brand-espresso hover:bg-brand-cocoa/5\'\n                    }`}\n                  >\n                    Hiker Lodge Pickup\n                  </button>\n                  <button\n                    type=\"button\"\n                    onClick={() => setFulfillmentType(\'delivery\')}\n                    className={`py-2 rounded-full font-display text-[10px] uppercase tracking-widest font-semibold transition-all cursor-pointer ${\n                      fulfillmentType === \'delivery\'\n                        ? \'bg-brand-espresso text-brand-cream shadow-sm\'\n                        : \'text-brand-espresso hover:bg-brand-cocoa/5\'\n                    }`}\n                  >\n                    Courier Delivery Links\n                  </button>\n                </div>\n\n                {/* SELF-PICKUP FORM */}\n                {fulfillmentType === \'pickup\' && (\n                  <div className=\"space-y-4 animate-fade-in\">\n                    <p className=\"text-xs text-brand-cocoa leading-relaxed font-light bg-brand-cream p-3 rounded-xl border\">\n                      <b>Self Pickup Note:</b> Items will be packaged in eco-fiber wood boxes and held ready for you at the central hearth counter. Enter your details below.\n                    </p>\n\n                    <div className=\"space-y-2\">\n                      <label htmlFor=\"ship-user-name\" className=\"block font-display text-[9.5px] uppercase tracking-widest\">Hiker Pickup Name</label>\n                      <input\n                        id=\"ship-user-name\"\n                        required\n                        type=\"text\"\n                        placeholder=\"e.g. Priyanjali Sen\"\n                        value={shippingDetails.name}\n                        onChange={(e) => setShippingDetails({ ...shippingDetails, name: e.target.value })}\n                        className=\"w-full px-4 py-3 rounded-xl bg-brand-cream border border-brand-cocoa/20 text-xs font-sans focus:border-brand-rust\"\n                      />\n                    </div>\n\n                    <div className=\"space-y-2\">\n                      <label htmlFor=\"ship-user-phone\" className=\"block font-display text-[9.5px] uppercase tracking-widest\">Mobile Contact Number</label>\n                      <input\n                        id=\"ship-user-phone\"\n                        required\n                        type=\"tel\"\n                        placeholder=\"e.g. +91 94180-XXXXX\"\n                        value={shippingDetails.phone}\n                        onChange={(e) => setShippingDetails({ ...shippingDetails, phone: e.target.value })}\n                        className=\"w-full px-4 py-3 rounded-xl bg-brand-cream border border-brand-cocoa/20 text-xs font-sans focus:border-brand-rust\"\n                      />\n                    </div>\n                  </div>\n                )}\n\n                {/* INSTANT COURIER LINKS */}\n                {fulfillmentType === \'delivery\' && (\n                  <div className=\"space-y-6 animate-fade-in pb-4\">\n                    <div className=\"text-xs text-brand-cocoa leading-relaxed font-light bg-brand-cream p-3 rounded-xl border\">\n                      <b>Fast Link Partner System:</b> You can submit your selections directly into our delivery integration channels:\n                    </div>\n\n                    {/* Partner Cards with nice badges */}\n                    <div className=\"space-y-3\">\n                      <a \n                        href=\"https://www.swiggy.com\" \n                        target=\"_blank\" \n                        rel=\"noopener noreferrer\"\n                        className=\"flex items-center justify-between p-4 bg-[#FC8019]/10 hover:bg-[#FC8019]/15 border border-[#FC8019]/30 rounded-2xl transition-shadow shadow-sm cursor-pointer\"\n                      >\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"text-xl font-bold text-[#FC8019] font-sans italic tracking-tighter\">swiggy</span>\n                          <span className=\"px-2 py-0.5 bg-[#FC8019] text-white text-[8px] font-bold tracking-widest uppercase rounded\">active</span>\n                        </div>\n                        <span className=\"font-display text-[9px] uppercase tracking-widest font-semibold text-[#FC8019] flex items-center gap-1\">\n                          Cart Direct Link\n                          <ChevronRight className=\"w-3.5 h-3.5\" />\n                        </span>\n                      </a>\n\n                      <a \n                        href=\"https://www.zomato.com/shimla\" \n                        target=\"_blank\" \n                        rel=\"noopener noreferrer\"\n                        className=\"flex items-center justify-between p-4 bg-[#CB202D]/10 hover:bg-[#CB202D]/15 border border-[#CB202D]/30 rounded-2xl transition-shadow shadow-sm cursor-pointer\"\n                      >\n                        <div className=\"flex items-center gap-3\">\n                          <span className=\"text-xl font-extrabold text-[#CB202D] font-sans tracking-tight\">zomato</span>\n                          <span className=\"px-2 py-0.5 bg-[#CB202D] text-white text-[8px] font-bold tracking-widest uppercase rounded\">active</span>\n                        </div>\n                        <span className=\"font-display text-[9px] uppercase tracking-widest font-semibold text-[#CB202D] flex items-center gap-1\">\n                          Cart Direct Link\n                          <ChevronRight className=\"w-3.5 h-3.5\" />\n                        </span>\n                      </a>\n                    </div>\n                    \n                    <p className=\"text-[11px] font-sans text-brand-cocoa font-light leading-relaxed\">\n                      *Tapping standard links transfers your items to Swiggy/Zomato Shimla region directories. Or you can submit via pickup mode here inside the.\n                    </p>\n                  </div>\n                )}\n\n              </div>\n\n              {/* Footer */}\n              <div className=\"p-6 bg-brand-cream border-t border-brand-cocoa/20 shrink-0 space-y-4\">\n                \n                <div className=\"flex justify-between items-center text-xs font-display uppercase tracking-widest\">\n                  <span className=\"text-brand-cocoa\">Amount Due</span>\n                  <span className=\"font-bold text-brand-rust\">${total.toFixed(2)}</span>\n                </div>\n\n                <div className=\"grid grid-cols-2 gap-4\">\n                  <button\n                    type=\"button\"\n                    onClick={() => setCheckoutStep(1)}\n                    className=\"px-4 py-3.5 border border-brand-cocoa/40 text-brand-espresso hover:bg-brand-cocoa/5 rounded-full font-display text-2xs uppercase tracking-widest font-semibold\"\n                  >\n                    Back to Items\n                  </button>\n                  <button\n                    type=\"submit\"\n                    className=\"px-4 py-3.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold cursor-pointer text-center\"\n                  >\n                    Confirm Order\n                  </button>\n                </div>\n\n              </div>\n\n            </form>\n          )}\n\n          {/* PHASE 3: TIMED PROCESS TRACKING SCREEN */}\n          {checkoutStep === 3 && (\n            <div className=\"flex-1 p-6 flex flex-col items-center justify-center text-center space-y-8 animate-fade-in\">\n              \n              <div className=\"space-y-1\">\n                <h3 className=\"font-serif text-2xl font-bold text-brand-pine\">Brewing Sent to Hearth!</h3>\n                {fulfillmentType === \'pickup\' ? (\n                  <p className=\"text-xs text-brand-cocoa\">Your order is logged under the name <span className=\"font-semibold text-brand-espresso\">{shippingDetails.name || \'Hiker\'}</span>.</p>\n                ) : (\n                  <p className=\"text-xs text-brand-cocoa\">Mock delivery channels successfully routed to Swiggy/Zomato partners.</p>\n                )}\n              </div>\n\n              {/* Glowing Extraction Animation Area */}\n              <div className=\"relative flex items-center justify-center\">\n                {/* Wave circle effect */}\n                <span className=\"absolute h-24 w-24 border-2 border-brand-rust bg-brand-rust/10 rounded-full animate-ping opacity-40\" />\n                <span className=\"absolute h-36 w-36 border border-brand-pine bg-brand-pine/5 rounded-full animate-pulse opacity-20\" />\n                \n                <div className=\"relative z-10 w-20 h-20 rounded-full bg-brand-espresso text-brand-cream shadow-2xl flex items-center justify-center border border-brand-gold\">\n                  <Coffee className=\"w-9 h-9 text-brand-gold animate-bounce\" />\n                </div>\n              </div>\n\n              {/* Status parameters list */}\n              <div className=\"w-full max-w-sm bg-brand-cream border text-left p-5 rounded-2xl space-y-3 font-display uppercase tracking-widest text-[9.5px]\">\n                <div className=\"flex justify-between items-center pb-2 border-b\">\n                  <span className=\"text-brand-cocoa\">Current status:</span>\n                  <span className=\"font-bold text-brand-rust text-right animate-pulse\">Woodfire Extracting...</span>\n                </div>\n                <div className=\"flex justify-between items-center\">\n                  <span className=\"text-brand-cocoa\">PREP TICK CLOCK:</span>\n                  <span className=\"font-semibold text-right\">~ 12 Minutes</span>\n                </div>\n                <div className=\"flex justify-between items-center\">\n                  <span className=\"text-brand-cocoa\">STATION INDEX:</span>\n                  <span className=\"font-semibold text-brand-pine text-right\">Hearth Fire 02</span>\n                </div>\n              </div>\n\n              <div className=\"pt-4 flex flex-col items-center gap-4 w-full\">\n                <p className=\"text-sans text-[11px] text-brand-cocoa leading-relaxed font-light italic max-w-xs\">\n                  \"The forest wood fires are roaring hot. Your extraction will be finished soon.\"\n                </p>\n                \n                <button\n                  onClick={() => {\n                    onClearCart(); // empty cart elements after checkout succeeded\n                    handleDismissCart();\n                  }}\n                  className=\"px-6 py-3.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold cursor-pointer shadow-md\"\n                >\n                  Confirm & Clear Session\n                </button>\n              </div>\n\n            </div>\n          )}\n\n        </div>\n      </div>\n\n    </div>\n  );\n};\n"
    }
