        }
        lines {
          text: "    name: \'Elena Rostova\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    role: \'Travel Journalist\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'I came in because of the logo\342\200\224the sweet Himalayan bear looking up at a pinecone. But I stayed for hours because of the warmth, the soft mountain lore, and the best green tea I have ever had.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
