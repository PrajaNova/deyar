g-widest font-semibold\">Email Mailbox</label>\n                  <input\n                    id=\"res-user-email\"\n                    required\n                    type=\"email\"\n                    placeholder=\"e.g. priya@senhikes.in\"\n                    value={formData.email}\n                    onChange={(e) => setFormData({ ...formData, email: e.target.value })}\n                    className=\"w-full px-4 py-3 rounded-sm bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  />\n                </div>\n\n                <div className=\"space-y-2 col-span-full sm:col-span-1\">\n                  <label id=\"res-phone-label\" htmlFor=\"res-phone\" className=\"block font-display text-[9.5px] uppercase tracking-widest font-semibold\">Mobile Trail Phone</label>\n                  <input\n                    id=\"res-phone\"\n                    required\n                    type=\"tel\"\n                    placeholder=\"e.g. +91 98160 54321\"\n                    value={formData.phone}\n                    onChange={(e) => setFormData({ ...formData, phone: e.target.value })}\n                    className=\"w-full px-4 py-3 rounded-sm bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  />\n                </div>\n              </div>\n\n              <div className=\"space-y-2\">\n                <label id=\"res-requests-label\" htmlFor=\"res-requests\" className=\"block font-display text-[9.5px] uppercase tracking-widest font-semibold\">Special Dietary or Seating Requests (Optional)</label>\n                <textarea\n                  id=\"res-requests\"\n                  placeholder=\"Need high-chairs, bringing pets, or requesting special floral tea steep packs?\"\n                  rows={3}\n                  value={formData.specialRequests}\n                  onChange={(e) => setFormData({ ...formData, specialRequests: e.target.value })}\n                  className=\"w-full p-4 rounded-sm bg-brand-cream-light border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                />\n              </div>\n\n              {/* Submit Buttons */}\n              <div className=\"grid grid-cols-2 gap-4 pt-4 border-t border-brand-cocoa/10\">\n                <button\n                  type=\"button\"\n                  onClick={() => setActiveStep(2)}\n                  className=\"px-5 py-3.5 border border-brand-cocoa/40 text-brand-espresso hover:bg-brand-cocoa/5 rounded-sm font-display text-2xs uppercase tracking-widest font-semibold\"\n                >\n                  Back to Seats\n                </button>\n                <button\n                  type=\"submit\"\n                  className=\"px-6 py-3.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-sm font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow-xs cursor-pointer text-center\"\n                >\n                  Generate Stamped Booking Ticket\n                </button>\n              </div>"
