  file_change {
    absolute_path_uri: "file:///src/components/Navbar.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { ShoppingCart, Menu, X, CalendarDays, Coffee } from \'lucide-react\';\nimport { DeyarLogo } from \'./DeyarLogo\';\n\ninterface NavbarProps {\n  currentPage: string;\n  setCurrentPage: (page: string) => void;\n  cartCount: number;\n  onCartClick: () => void;\n}\n\nexport const Navbar: React.FC<NavbarProps> = ({\n  currentPage,\n  setCurrentPage,\n  cartCount,\n  onCartClick,\n}) => {\n  const [mobileMenuOpen, setMobileMenuOpen] = React.useState(false);\n\n  const navItems = [\n    { id: \'home\', label: \'Home\' },\n    { id: \'menu\', label: \'Menu\' },\n    { id: \'about\', label: \'About Us\' },\n    { id: \'reserve\', label: \'Book Table\' },\n    { id: \'contact\', label: \'Hours & Contact\' },\n  ];\n\n  const handleNavClick = (id: string) => {\n    setCurrentPage(id);\n    setMobileMenuOpen(false);\n    window.scrollTo({ top: 0, behavior: \'smooth\' });\n  };\n\n  return (\n    <header className=\"sticky top-0 z-40 w-full bg-brand-cream/95 backdrop-blur-md border-b border-brand-cocoa/20 shadow-sm transition-all duration-300\">\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\">\n        <div className=\"flex items-center justify-between h-20\">\n          \n          {/* Brand Logo & Name */}\n          <button \n            onClick={() => handleNavClick(\'home\')}\n            className=\"flex items-center gap-3 group text-left cursor-pointer\"\n          >\n            {/* Minimal Logo Symbol */}\n            <div className=\"w-12 h-12 bg-brand-espresso rounded-full overflow-hidden flex items-center justify-center p-0.5 border border-brand-rust/30 transition-transform duration-300 group-hover:scale-105 shadow-inner\">\n              <DeyarLogo size={42} variant=\"bear-only\" className=\"w-full h-full scale-105\" />\n            </div>\n            <div>\n              <span className=\"font-serif text-2xl font-semibold tracking-wider text-brand-espresso block leading-none\">\n                DEYAR\n              </span>\n              <span className=\"font-display text-[9px] uppercase tracking-[0.2em] text-brand-rust block mt-1\">\n                Himachal Mountain Caf\303\251\n              </span>\n            </div>\n          </button>\n\n          {/* Desktop Navigation */}\n          <nav className=\"hidden md:flex items-center gap-8\">\n            {navItems.map((item) => (\n              <button\n                key={item.id}\n                onClick={() => handleNavClick(item.id)}\n                className={`relative px-1 py-2 font-display text-sm uppercase tracking-widest font-medium transition-colors duration-300 cursor-pointer ${\n                  currentPage === item.id \n                    ? \'text-brand-rust\' \n                    : \'text-brand-espresso/80 hover:text-brand-rust\'\n                }`}\n              >\n                {item.label}\n                {currentPage === item.id && (\n                  <span className=\"absolute bottom-0 left-0 w-full h-0.5 bg-brand-rust rounded-full\" />\n                )}\n              </button>\n            ))}\n          </nav>\n\n          {/* Action Buttons - Cart & Booking Shortcut */}\n          <div className=\"flex items-center gap-4\">\n            \n            {/* Reservations Shortcut Icon Button */}\n            <button\n              onClick={() => handleNavClick(\'reserve\')}\n              className={`hidden sm:flex items-center gap-2 px-4 py-2 border border-brand-rust/40 rounded-full font-display text-xs uppercase tracking-widest font-semibold transition-all duration-300 hover:bg-brand-rust hover:text-brand-cream hover:border-brand-rust cursor-pointer ${\n                currentPage === \'reserve\' \n                  ? \'bg-brand-rust text-brand-cream border-brand-rust\' \n                  : \'text-brand-espresso bg-transparent\'\n              }`}\n            >\n              <CalendarDays className=\"w-3.5 h-3.5\" />\n              Reservations\n            </button>\n\n            {/* Shopping Cart button */}\n            <button\n              onClick={onCartClick}\n              className=\"relative p-2.5 bg-brand-espresso text-brand-cream rounded-full shadow-md hover:bg-brand-rust transition-colors duration-300 group cursor-pointer border border-brand-rust/10\"\n              aria-label=\"Toggle Shopping Cart\"\n            >\n              <ShoppingCart className=\"w-4 h-4 transition-transform duration-300 group-hover:scale-105\" />\n              {cartCount > 0 && (\n                <span className=\"absolute -top-1 -right-1 flex h-5 w-5 items-center justify-center rounded-full bg-brand-rust text-[10px] font-bold text-brand-cream border-2 border-brand-cream animate-bounce\">\n                  {cartCount}\n                </span>\n              )}\n            </button>\n\n            {/* Mobile Menu Toggle Button */}\n            <button\n              onClick={() => setMobileMenuOpen(!mobileMenuOpen)}\n              className=\"md:hidden p-2 text-brand-espresso hover:text-brand-rust transition-colors\"\n              aria-label=\"Toggle Navigation Menu\"\n            >\n              {mobileMenuOpen ? <X className=\"w-6 h-6\" /> : <Menu className=\"w-6 h-6\" />}\n            </button>\n          </div>\n\n        </div>\n      </div>\n\n      {/* Mobile Drawer Menu */}\n      {mobileMenuOpen && (\n        <div className=\"md:hidden border-t border-brand-cocoa/20 bg-brand-cream px-4 py-6 space-y-3 shadow-lg animate-fade-in\">\n          {navItems.map((item) => (\n            <button\n              key={item.id}\n              onClick={() => handleNavClick(item.id)}\n              className={`w-full text-left px-4 py-3 rounded-lg font-display text-sm uppercase tracking-widest font-medium transition-all ${\n                currentPage === item.id \n                  ? \'bg-brand-rust/10 text-brand-rust pl-6\' \n                  : \'text-brand-espresso hover:bg-brand-cocoa/5\'\n              }`}\n            >\n              {item.label}\n            </button>\n          ))}\n          <button\n            onClick={() => handleNavClick(\'reserve\')}\n            className=\"w-full flex items-center justify-center gap-2 mt-4 px-4 py-3 bg-brand-rust text-brand-cream rounded-lg font-display text-sm uppercase tracking-widest font-semibold hover:bg-brand-espresso transition-colors duration-300\"\n          >\n            <CalendarDays className=\"w-4 h-4\" />\n            Book a Table\n          </button>\n        </div>\n      )}\n    </header>\n  );\n};\n"
    }
