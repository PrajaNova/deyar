  file_change {
    absolute_path_uri: "file:///src/components/MenuSection.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React, { useState, useMemo } from \'react\';\nimport { Search, Info, Plus, ChevronRight, Check, X, ShieldAlert, Sparkles, Filter } from \'lucide-react\';\nimport { MENU_ITEMS } from \'../data\';\nimport { MenuItem, CartItem } from \'../types\';\n\ninterface MenuSectionProps {\n  onAddToCart: (item: MenuItem, quantity: number, selectedOptions: { [key: string]: string }, notes: string) => void;\n}\n\nexport const MenuSection: React.FC<MenuSectionProps> = ({ onAddToCart }) => {\n  // Navigation & Search State\n  const [activeCategory, setActiveCategory] = useState<\'all\' | \'coffee\' | \'tea\' | \'pastries\' | \'seasonal\'>(\'all\');\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  \n  // Customization Modal State\n  const [selectedItem, setSelectedItem] = useState<MenuItem | null>(null);\n  const [modalOpen, setModalOpen] = useState(false);\n  const [customOptions, setCustomOptions] = useState<{ [key: string]: string }>({});\n  const [customNotes, setCustomNotes] = useState(\'\');\n  const [qty, setQty] = useState(1);\n\n  // Quick Action notification state\n  const [toastMessage, setToastMessage] = useState<string | null>(null);\n\n  // Categories list\n  const categoriesMap = [\n    { id: \'all\', label: \'Full Forest Guild\' },\n    { id: \'coffee\', label: \'Coffee Crafts\' },\n    { id: \'tea\', label: \'Valley infusions\' },\n    { id: \'pastries\', label: \'Hearth Pastries\' },\n    { id: \'seasonal\', label: \'Seasonal Rotations\' },\n  ];\n\n  // Filtering Logic\n  const filteredItems = useMemo(() => {\n    return MENU_ITEMS.filter((item) => {\n      const matchCategory = activeCategory === \'all\' || item.category === activeCategory;\n      const matchSearch = item.name.toLowerCase().includes(searchQuery.toLowerCase()) || \n                          item.description.toLowerCase().includes(searchQuery.toLowerCase()) ||\n                          item.tags.some(t => t.toLowerCase().includes(searchQuery.toLowerCase()));\n      return matchCategory && matchSearch;\n    });\n  }, [activeCategory, searchQuery]);\n\n  // Open customization dialog\n  const handleOpenCustomization = (item: MenuItem) => {\n    setSelectedItem(item);\n    \n    // Initialize default options\n    const defaults: { [key: string]: string } = {};\n    if (item.customizationOptions) {\n      item.customizationOptions.forEach((opt) => {\n        defaults[opt.name] = opt.options[0]; // first option remains default\n      });\n    }\n    setCustomOptions(defaults);\n    setCustomNotes(\'\');\n    setQty(1);\n    setModalOpen(true);\n  };\n\n  // Option price modifier helper\n  const calculateOptionModTotal = (optionsMap: { [key: string]: string }) => {\n    let extra = 0;\n    Object.keys(optionsMap).forEach((key) => {\n      const val = optionsMap[key];\n      if (val.includes(\'+ $\')) {\n        const parts = val.split(\'+ $\');\n        if (parts.length > 1) {\n          const amount = parseFloat(parts[1]);\n          if (!isNaN(amount)) {\n            extra += amount;\n          }\n        }\n      }\n    });\n    return extra;\n  };\n\n  // Base + Mod price calculations\n  const itemPrice = useMemo(() => {\n    if (!selectedItem) return 0;\n    const modifierTotal = calculateOptionModTotal(customOptions);\n    return (selectedItem.price + modifierTotal) * qty;\n  }, [selectedItem, customOptions, qty]);\n\n  // Handle add to cart submission\n  const handleConfirmAdd = () => {\n    if (!selectedItem) return;\n    \n    // Call parent handler\n    onAddToCart(selectedItem, qty, customOptions, customNotes);\n    setModalOpen(false);\n\n    // Trigger sliding success toast\n    setToastMessage(`Added ${qty}x ${selectedItem.name} to order!`);\n    setTimeout(() => {\n      setToastMessage(null);\n    }, 4000);\n  };\n\n  return (\n    <section className=\"bg-brand-cream-light py-12 px-4 sm:px-6 lg:px-8 w-full min-h-[85vh] text-brand-espresso\">\n      \n      {/* 1. Page Header */}\n      <div className=\"max-w-4xl mx-auto text-center mb-12\">\n        <span className=\"font-display text-xs uppercase tracking-[0.25em] text-brand-rust block mb-2\">ARTISANAL WOODFIRED COFFEE & TEA</span>\n        <h1 className=\"font-serif text-4xl md:text-5xl font-bold tracking-tight mb-4\">\n          Deyar Kitchen Menu\n        </h1>\n        <p className=\"font-sans text-sm text-brand-cocoa max-w-lg mx-auto\">\n          Explore single-origin coffee extracted on woodfire, botanical blends steeped with seasonal flowers, and traditional rolls glazed in forest honey.\n        </p>\n        <div className=\"h-0.5 w-16 bg-brand-rust mx-auto mt-4\" />\n      </div>\n\n      {/* 2. Interactive Search & Filters controls */}\n      <div className=\"max-w-6xl mx-auto space-y-6 mb-12\">\n        <div className=\"flex flex-col md:flex-row gap-4 items-center justify-between\">\n          \n          {/* Categories Button Row */}\n          <div className=\"flex flex-wrap gap-2 justify-center w-full md:w-auto\">\n            {categoriesMap.map((cat) => (\n              <button\n                key={cat.id}\n                onClick={() => {\n                  setActiveCategory(cat.id as any);\n                  // Quick tracking trigger\n                }}\n                className={`px-4 py-2 rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 pointer-events-auto cursor-pointer ${\n                  activeCategory === cat.id\n                    ? \'bg-brand-espresso text-brand-cream-light shadow-md\'\n                    : \'bg-brand-cream border border-brand-cocoa/20 text-brand-espresso hover:border-brand-espresso/80\'\n                }`}\n              >\n                {cat.label}\n              </button>\n            ))}\n          </div>\n\n          {/* Search box block */}\n          <div className=\"relative w-full md:max-w-xs\">\n            <span className=\"absolute inset-y-0 left-0 flex items-center pl-3.5 pointer-events-none text-brand-cocoa\">\n              <Search className=\"w-4 h-4\" />\n            </span>\n            <input\n              type=\"text\"\n              placeholder=\"Search woodfired brews...\"\n              value={searchQuery}\n              onChange={(e) => setSearchQuery(e.target.value)}\n              className=\"w-full pl-10 pr-4 py-2.5 rounded-full bg-brand-cream border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none transition-shadow font-sans text-xs\"\n            />\n            {searchQuery && (\n              <button\n                onClick={() => setSearchQuery(\'\')}\n                className=\"absolute inset-y-0 right-0 flex items-center pr-3 text-brand-espresso/50 hover:text-brand-espresso\"\n              >\n                <X className=\"w-3.5 h-3.5\" />\n              </button>\n            )}\n          </div>\n\n        </div>\n      </div>\n\n      {/* 3. Items Dynamic Catalog Grid */}\n      <div className=\"max-w-6xl mx-auto\">\n        {filteredItems.length === 0 ? (\n          <div className=\"text-center py-20 bg-brand-cream rounded-3xl border border-dashed border-brand-cocoa/30 p-8 max-w-md mx-auto\">\n            <ShieldAlert className=\"w-12 h-12 text-brand-rust/60 mx-auto mb-4\" />\n            <h3 className=\"font-serif text-xl font-bold mb-2\">No Forest Delicacies Found</h3>\n            <p className=\"font-sans text-xs text-brand-cocoa leading-relaxed mb-4\">\n              We couldn\'t find matches for \"{searchQuery}\". Try searching for popular ingredients like \"honey\", \"espresso\", or \"scone\".\n            </p>\n            <button\n              onClick={() => {\n                setSearchQuery(\'\');\n                setActiveCategory(\'all\');\n              }}\n              className=\"px-5 py-2.5 bg-brand-espresso text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold\"\n            >\n              Reset Filters\n            </button>\n          </div>\n        ) : (\n          <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8\">\n            {filteredItems.map((item) => (\n              <article \n                key={item.id}\n                className=\"group flex flex-col bg-brand-cream rounded-2xl overflow-hidden border border-brand-cocoa/10 shadow hover:shadow-lg transition-all duration-300 transform hover:-translate-y-1\"\n                id={`menu-item-${item.id}`}\n              >\n                \n                {/* Product Image Frame */}\n                <div className=\"relative aspect-[4/3] overflow-hidden bg-brand-dark/20 border-b border-brand-cocoa/10\">\n                  <img\n                    src={item.image}\n                    alt={item.name}\n                    className=\"w-full h-full object-cover group-hover:scale-105 transition-transform duration-500\"\n                    referrerPolicy=\"no-referrer\"\n                  />\n                  {/* Category Pill Tag */}\n                  <div className=\"absolute top-3 left-3 bg-brand-cream/90 backdrop-blur-sm px-2.5 py-0.5 rounded-md font-display text-[9px] font-semibold uppercase tracking-widest text-brand-espresso border border-brand-cocoa/2s shadow-sm\">\n                    {item.category}\n                  </div>\n                  \n                  {/* Seasonal glow badge */}\n                  {item.isSeasonal && (\n                    <div className=\"absolute top-3 right-3 bg-brand-rust text-brand-cream px-2 py-0.5 rounded-md font-display text-[8.5px] font-bold uppercase tracking-widest shadow-md flex items-center gap-1 animate-pulse\">\n                      <Sparkles className=\"w-2.5 h-2.5 text-brand-gold\" />\n                      Seasonal\n                    </div>\n                  )}\n                </div>\n\n                {/* Card Content details */}\n                <div className=\"p-5 flex-1 flex flex-col justify-between space-y-4\">\n                  <div className=\"space-y-2\">\n                    <div className=\"flex items-start justify-between gap-1.5\">\n                      <h3 className=\"font-serif text-lg font-bold text-brand-espresso group-hover:text-brand-rust transition-colors leading-snug\">\n                        {item.name}\n                      </h3>\n                      <span className=\"font-display font-semibold text-brand-rust text-base shrink-0\">\n                        ${item.price.toFixed(2)}\n                      </span>\n                    </div>\n\n                    <p className=\"font-sans text-xs text-brand-espresso/70 leading-relaxed font-light line-clamp-3\">\n                      {item.description}\n                    </p>\n                  </div>\n\n                  <div className=\"space-y-3 pt-2\">\n                    {/* Item organic labels */}\n                    <div className=\"flex flex-wrap gap-1.5\">\n                      {item.tags.map((tag, idx) => (\n                        <span key={idx} className=\"px-2 py-0.5 bg-brand-pine/5 text-brand-pine text-[8.5px] font-semibold tracking-wider uppercase rounded-md border border-brand-pine/10\">\n                          {tag}\n                        </span>\n                      ))}\n                    </div>\n\n                    <div className=\"pt-2 border-t border-brand-cocoa/10 flex items-center justify-between\">\n                      <button\n                        onClick={() => handleOpenCustomization(item)}\n                        className=\"inline-flex items-center gap-1 text-[11px] font-display uppercase tracking-widest text-brand-espresso/70 hover:text-brand-rust font-semibold transition-colors cursor-pointer\"\n                      >\n                        <Info className=\"w-3.5 h-3.5\" />\n                        Details / Customize\n                      </button>\n\n                      <button\n                        onClick={() => {\n                          // Bypass customization with defaults\n                          const defaults: { [key: string]: string } = {};\n                          if (item.customizationOptions) {\n                            item.customizationOptions.forEach(opt => {\n                              defaults[opt.name] = opt.options[0];\n                            });\n                          }\n                          onAddToCart(item, 1, defaults, \'\');\n                          setToastMessage(`Added ${item.name} to order with standard options.`);\n                          setTimeout(() => setToastMessage(null), 3000);\n                        }}\n                        className=\"p-1.5 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full transition-transform hover:scale-105 shadow cursor-pointer border border-brand-rust/10\"\n                        aria-label=\"Add to cart with standard options\"\n                      >\n                        <Plus className=\"w-4 h-4\" />\n                      </button>\n                    </div>\n                  </div>\n\n                </div>\n\n              </article>\n            ))}\n          </div>\n        )}\n      </div>\n\n      {/* 4. Customization Modal Dialog Frame */}\n      {modalOpen && selectedItem && (\n        <div className=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-brand-dark/60 backdrop-blur-xs animate-fade-in\">\n          <div \n            className=\"w-full max-w-lg bg-brand-cream-light rounded-3xl overflow-hidden border border-brand-rust/20 shadow-2xl flex flex-col max-h-[90vh]\"\n            onClick={(e) => e.stopPropagation()}\n          >\n            \n            {/* Modal Image banner */}\n            <div className=\"relative h-44 shrink-0 bg-brand-dark/20\">\n              <img\n                src={selectedItem.image}\n                alt={selectedItem.name}\n                className=\"w-full h-full object-cover\"\n                referrerPolicy=\"no-referrer\"\n              />\n              <button \n                onClick={() => setModalOpen(false)}\n                className=\"absolute top-4 right-4 p-2 bg-brand-dark/80 hover:bg-brand-rust text-brand-cream rounded-full cursor-pointer transition-colors shadow-md text-white\"\n                aria-label=\"Close dialog\"\n              >\n                <X className=\"w-4 h-4\" />\n              </button>\n              <div className=\"absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent flex items-end p-5\">\n                <span className=\"font-serif text-2xl font-bold text-white tracking-wide\">{selectedItem.name}</span>\n              </div>\n            </div>\n\n            {/* Modal Content container */}\n            <div className=\"p-6 flex-1 overflow-y-auto space-y-6 subtle-scroll\">\n              \n              <div className=\"space-y-2\">\n                <h4 className=\"font-display text-[10px] uppercase tracking-widest text-brand-rust font-bold\">Chef\'s Recipe Commentary</h4>\n                <p className=\"font-sans text-xs md:text-sm text-brand-espresso/85 leading-relaxed font-light\">\n                  {selectedItem.description}\n                </p>\n                <div className=\"flex gap-2 pt-1.5\">\n                  {selectedItem.tags.map((tag, i) => (\n                    <span key={i} className=\"px-2 py-0.5 bg-brand-pine/10 text-brand-pine text-[8.5px] uppercase tracking-wider font-semibold rounded\">{tag}</span>\n                  ))}\n                </div>\n              </div>\n\n              {/* Dynamic Customization Options Panel */}\n              {selectedItem.customizationOptions && selectedItem.customizationOptions.length > 0 && (\n                <div className=\"space-y-5 border-t border-brand-cocoa/15 pt-5\">\n                  {selectedItem.customizationOptions.map((option) => (\n                    <div key={option.name} className=\"space-y-2\">\n                      <h5 className=\"font-display text-[11px] uppercase tracking-widest text-brand-espresso font-semibold\">{option.name}</h5>\n                      \n                      <div className=\"flex flex-wrap gap-2\">\n                        {option.options.map((val) => {\n                          const isSelected = customOptions[option.name] === val;\n                          return (\n                            <button\n                              key={val}\n                              onClick={() => setCustomOptions({ ...customOptions, [option.name]: val })}\n                              className={`px-3 py-1.5 rounded-full text-xs font-sans transition-all cursor-pointer ${\n                                isSelected\n                                  ? \'bg-brand-rust text-brand-cream font-medium shadow-sm\'\n                                  : \'bg-brand-cream border border-brand-cocoa/20 text-brand-espresso hover:border-brand-espresso/60\'\n                              }`}\n                            >\n                              {val}\n                            </button>\n                          );\n                        })}\n                      </div>\n                    </div>\n                  ))}\n                </div>\n              )}\n\n              {/* Special instructions block */}\n              <div className=\"space-y-2 border-t border-brand-cocoa/15 pt-5\">\n                <label htmlFor=\"custom-notes-input\" className=\"block font-display text-[11px] uppercase tracking-widest text-brand-espresso font-semibold\">Special Prep Notes</label>\n                <p className=\"text-[10px] font-sans text-brand-cocoa mb-1.5\">e.g., extra hot, light foam, sweetener on side</p>\n                <textarea\n                  id=\"custom-notes-input\"\n                  className=\"w-full p-3 rounded-xl bg-brand-cream border border-brand-cocoa/20 focus:border-brand-rust focus:ring-1 focus:ring-brand-rust outline-none font-sans text-xs\"\n                  placeholder=\"Notes for our baristas...\"\n                  rows={2}\n                  maxLength={150}\n                  value={customNotes}\n                  onChange={(e) => setCustomNotes(e.target.value)}\n                />\n              </div>\n\n            </div>\n\n            {/* Modal Action Footer */}\n            <div className=\"p-6 shrink-0 bg-brand-cream border-t border-brand-cocoa/20 flex flex-col sm:flex-row items-center justify-between gap-4\">\n              \n              {/* Quantity Counter */}\n              <div className=\"flex items-center gap-3 border border-brand-cocoa/30 rounded-full px-3 py-1 bg-brand-cream-light\">\n                <button\n                  disabled={qty <= 1}\n                  onClick={() => setQty(qty - 1)}\n                  className=\"w-8 h-8 rounded-full bg-brand-cream hover:bg-brand-cocoa/10 flex items-center justify-center font-sans font-bold cursor-pointer transition-colors disabled:opacity-40\"\n                >\n                  -\n                </button>\n                <span className=\"font-display font-semibold text-sm w-4 text-center\">{qty}</span>\n                <button\n                  onClick={() => setQty(qty + 1)}\n                  className=\"w-8 h-8 rounded-full bg-brand-cream hover:bg-brand-cocoa/10 flex items-center justify-center font-sans font-bold cursor-pointer transition-colors\"\n                >\n                  +\n                </button>\n              </div>\n\n              {/* Price Calculation & Adding Button */}\n              <div className=\"flex items-center gap-4 w-full sm:w-auto justify-end\">\n                <div className=\"text-right\">\n                  <span className=\"block font-display text-[9px] uppercase tracking-widest text-brand-cocoa\">Subtotal Amount</span>\n                  <span className=\"block font-display text-lg font-semibold text-brand-rust leading-none\">${itemPrice.toFixed(2)}</span>\n                </div>\n                <button\n                  onClick={handleConfirmAdd}\n                  className=\"px-6 py-3 bg-brand-espresso hover:bg-brand-rust text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow cursor-pointer flex items-center gap-1.5\"\n                >\n                  <Plus className=\"w-3.5 h-3.5\" />\n                  Add to order\n                </button>\n              </div>\n\n            </div>\n\n          </div>\n        </div>\n      )}\n\n      {/* Floating sliding checkout Toast notice code */}\n      {toastMessage && (\n        <div className=\"fixed bottom-6 right-6 z-50 bg-brand-pine text-brand-cream px-5 py-3.5 rounded-2xl shadow-2xl border border-brand-gold/30 flex items-center gap-3 animate-fade-in max-w-sm pointer-events-auto\">\n          <div className=\"w-6 h-6 rounded-full bg-brand-cream/10 flex items-center justify-center shrink-0\">\n            <Check className=\"w-3.5 h-3.5 text-brand-gold\" />\n          </div>\n          <p className=\"font-sans text-xs leading-relaxed font-light\">{toastMessage}</p>\n        </div>\n      )}\n\n    </section>\n  );\n};\n"
