        }
        lines {
          text: "    name: \'Devendra Thakur\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    role: \'Trek Guide\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    text: \'After a long trek in the cold peaks, having a hot Wild Honey Cortado at Deyar tastes like heaven. Love that they preserve Himachali folklore and support our regional wild bee farmers.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rating: 5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
