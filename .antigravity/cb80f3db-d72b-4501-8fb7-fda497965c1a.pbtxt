    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "import { useState } from \'react\';\nimport { Navbar } from \'./components/Navbar\';\nimport { Hero } from \'./components/Hero\';\nimport { MenuSection } from \'./components/MenuSection\';\nimport { AboutSection } from \'./components/AboutSection\';\nimport { ReservationSection } from \'./components/ReservationSection\';\nimport { ContactSection } from \'./components/ContactSection\';\nimport { Testimonials } from \'./components/Testimonials\';\nimport { Footer } from \'./components/Footer\';\nimport { CartDrawer } from \'./components/CartDrawer\';\nimport { CartItem, MenuItem } from \'./types\';\n\nexport default function App() {\n  // Navigation State Routing\n  const [currentPage, setCurrentPage] = useState<string>(\'home\');\n\n  // Interactive Cart Overlay State\n  const [cartItems, setCartItems] = useState<CartItem[]>([]);\n  const [cartOpen, setCartOpen] = useState<boolean>(false);\n\n  // CART STATE HANDLERS\n\n  // Add Item to Order with customizable options & notes\n  const handleAddToCart = (\n    menuItem: MenuItem,\n    quantity: number,\n    selectedOptions: { [key: string]: string },\n    notes: string\n  ) => {\n    // Generate a unique line-id from items and specific option configurations\n    const optionsHash = Object.keys(selectedOptions)\n      .sort()\n      .map((k) => `${k}:${selectedOptions[k]}`)\n      .join(\'|\');\n    const cartItemId = `${menuItem.id}-${optionsHash}`;\n\n    setCartItems((prevItems) => {\n      const matchIdx = prevItems.findIndex((item) => item.id === cartItemId);\n      if (matchIdx > -1) {\n        // Line exists, increment quantity\n        const updated = [...prevItems];\n        updated[matchIdx].quantity += quantity;\n        return updated;\n      } else {\n        // Create new cart row line\n        const newItem: CartItem = {\n          id: cartItemId,\n          menuItem,\n          quantity,\n          selectedOptions,\n          notes,\n        };\n        return [...prevItems, newItem];\n      }\n    });\n  };\n\n  // Quick standard add bypass (utilizes the first choice in each option)\n  const handleQuickAdd = (menuItem: MenuItem) => {\n    const defaults: { [key: string]: string } = {};\n    if (menuItem.customizationOptions) {\n      menuItem.customizationOptions.forEach((opt) => {\n        defaults[opt.name] = opt.options[0];\n      });\n    }\n    handleAddToCart(menuItem, 1, defaults, \'\');\n    \n    // Automatically toggle cart panel open so hiker sees visual line confirmation\n    setCartOpen(true);\n  };\n\n  // Adjust item quantities inside Cart drawer rows\n  const handleUpdateQty = (cartItemId: string, newQty: number) => {\n    if (newQty <= 0) {\n      handleRemoveItem(cartItemId);\n    } else {\n      setCartItems((prev) =>\n        prev.map((item) => (item.id === cartItemId ? { ...item, quantity: newQty } : item))\n      );\n    }\n  };\n\n  // Remove lines completely from Cart\n  const handleRemoveItem = (cartItemId: string) => {\n    setCartItems((prev) => prev.filter((item) => item.id !== cartItemId));\n  };\n\n  // Reset entire shopping session\n  const handleClearCart = () => {\n    setCartItems([]);\n  };\n\n  // Count total units inside Cart badge\n  const totalCartCount = cartItems.reduce((acc, item) => acc + item.quantity, 0);\n\n  return (\n    <div className=\"min-h-screen bg-brand-cream text-brand-dark flex flex-col justify-between\" id=\"app-viewport\">\n      \n      {/* Dynamic Sticky Header Navigation */}\n      <Navbar\n        currentPage={currentPage}\n        setCurrentPage={setCurrentPage}\n        cartCount={totalCartCount}\n        onCartClick={() => setCartOpen(true)}\n      />\n\n      {/* Main Pages Switchboard Panel */}\n      <main className=\"flex-1\">\n        {currentPage === \'home\' && (\n          <div className=\"animate-fade-in\">\n            <Hero setCurrentPage={setCurrentPage} onQuickAdd={handleQuickAdd} />\n            <Testimonials />\n          </div>\n        )}\n        \n        {currentPage === \'menu\' && (\n          <div className=\"animate-fade-in\">\n            <MenuSection onAddToCart={handleAddToCart} />\n          </div>\n        )}\n        \n        {currentPage === \'about\' && (\n          <div className=\"animate-fade-in\">\n            <AboutSection />\n          </div>\n        )}\n        \n        {currentPage === \'reserve\' && (\n          <div className=\"animate-fade-in\">\n            <ReservationSection />\n          </div>\n        )}\n        \n        {currentPage === \'contact\' && (\n          <div className=\"animate-fade-in\">\n            <ContactSection />\n          </div>\n        )}\n      </main>\n\n      {/* Global Page Footer */}\n      <Footer setCurrentPage={setCurrentPage} />\n\n      {/* Sliding Side Order Cart Panel Overlay */}\n      <CartDrawer\n        isOpen={cartOpen}\n        onClose={() => setCartOpen(false)}\n        cartItems={cartItems}\n        onUpdateQty={handleUpdateQty}\n        onRemoveItem={handleRemoveItem}\n        onClearCart={handleClearCart}\n      />\n\n    </div>\n  );\n}"
      replacement_content: "import { useState } from \'react\';\nimport { Navbar } from \'./components/Navbar\';\nimport { Hero } from \'./components/Hero\';\nimport { MenuSection } from \'./components/MenuSection\';\nimport { AboutSection } from \'./components/AboutSection\';\nimport { ContactSection } from \'./components/ContactSection\';\nimport { Testimonials } from \'./components/Testimonials\';\nimport { Footer } from \'./components/Footer\';\n\nexport default function App() {\n  // Navigation State Routing\n  const [currentPage, setCurrentPage] = useState<string>(\'home\');\n\n  return (\n    <div className=\"min-h-screen bg-brand-cream text-brand-dark flex flex-col justify-between\" id=\"app-viewport\">\n      \n      {/* Dynamic Sticky Header Navigation */}\n      <Navbar\n        currentPage={currentPage}\n        setCurrentPage={setCurrentPage}\n      />\n\n      {/* Main Pages Switchboard Panel */}\n      <main className=\"flex-1\">\n        {currentPage === \'home\' && (\n          <div className=\"animate-fade-in\">\n            <Hero setCurrentPage={setCurrentPage} />\n            <Testimonials />\n          </div>\n        )}\n        \n        {currentPage === \'menu\' && (\n          <div className=\"animate-fade-in\">\n            <MenuSection />\n          </div>\n        )}\n        \n        {currentPage === \'about\' && (\n          <div className=\"animate-fade-in\">\n            <AboutSection />\n          </div>\n        )}\n        \n        {currentPage === \'contact\' && (\n          <div className=\"animate-fade-in\">\n            <ContactSection />\n          </div>\n        )}\n      </main>\n\n      {/* Global Page Footer */}\n      <Footer setCurrentPage={setCurrentPage} />\n\n    </div>\n  );\n}"
    }
