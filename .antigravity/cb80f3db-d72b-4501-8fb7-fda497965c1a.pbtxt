    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import React from \'react\';\nimport { ArrowRight, Leaf, Sparkles, Trophy, Flame } from \'lucide-react\';\nimport { DeyarLogo } from \'./DeyarLogo\';\nimport { MENU_ITEMS, CAFE_STORY } from \'../data\';\nimport { MenuItem } from \'../types\';\n\ninterface HeroProps {\n  setCurrentPage: (page: string) => void;\n  onQuickAdd: (item: MenuItem) => void;\n}\n\nexport const Hero: React.FC<HeroProps> = ({ setCurrentPage, onQuickAdd }) => {\n  // Get seasonal items for showcase\n  const seasonalItems = MENU_ITEMS.filter((item) => item.category === \'seasonal\');\n\n  // Interactive local testimonial toggle\n  const [activeSpecial, setActiveSpecial] = React.useState(0);\n\n  return (\n    <div className=\"w-full\">\n      {/* 1. Primary Splash & Core Hero Branding */}\n      <section className=\"relative min-h-[90vh] flex flex-col items-center justify-center py-16 px-4 bg-gradient-to-b from-brand-cream to-brand-cream-light relative overflow-hidden\">\n        \n        {/* Subtle decorative mountain-peak outlines in background */}\n        <div className=\"absolute inset-0 z-0 opacity-10 pointer-events-none select-none\">\n          <svg className=\"w-full h-full\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 1000 1000\" preserveAspectRatio=\"none\">\n            <path d=\"M0,800 L250,550 L400,700 L700,350 L1000,750 L1000,1000 L0,1000 Z\" fill=\"#845D4B\" />\n          </svg>\n        </div>\n\n        {/* Ambient Floating Pine Needles (CSS stylized) */}\n        <div className=\"absolute inset-0 pointer-events-none overflow-hidden z-0\">\n          <div className=\"absolute top-[18%] left-[8%] w-4 h-4 bg-brand-pine/10 rounded-full blur-sm\" />\n          <div className=\"absolute top-[40%] right-[10%] w-6 h-6 bg-brand-rust/5 rounded-full blur-sm\" />\n          <div className=\"absolute bottom-[20%] left-[12%] w-5 h-5 bg-brand-gold/10 rounded-full blur-md\" />\n        </div>\n\n        <div className=\"max-w-4xl mx-auto text-center z-10 flex flex-col items-center\">\n          \n          {/* Animated Signature Brand Seal Emblem */}\n          <div className=\"mb-8\">\n            <DeyarLogo size={240} variant=\"emblem\" />\n          </div>\n\n          {/* Tagline Accent Pill */}\n          <div className=\"inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-pine/10 text-brand-pine font-display text-[11px] font-semibold tracking-[0.25em] uppercase mb-6 border border-brand-pine/20\">\n            <Leaf className=\"w-3.5 h-3.5\" />\n            Storytelling & Mountain Botany\n          </div>\n\n          {/* Master Display Typography */}\n          <h1 className=\"font-serif text-5xl md:text-7xl font-bold tracking-tight text-brand-espresso mb-6 leading-[1.12]\">\n            Grown in Himalayan Forest Stories, <br className=\"hidden md:inline\" />\n            <span className=\"text-brand-rust italic font-normal\">Smoked in Woodfire.</span>\n          </h1>\n\n          <p className=\"font-sans text-base md:text-xl text-brand-espresso/80 max-w-2xl font-light leading-relaxed mb-10\">\n            Deyar is a cozy, artisanal refuge rooted in Shimla\342\200\231s pristine Deodar forest folklore. Crafting high-altitude beans, heritage wild-botanical infusions, and traditional wood-smoked delicacies.\n          </p>\n\n          {/* Core App Direction Flows */}\n          <div className=\"flex flex-col sm:flex-row items-center justify-center gap-4 w-full sm:w-auto px-4\">\n            <button\n              onClick={() => {\n                setCurrentPage(\'menu\');\n                window.scrollTo({ top: 0, behavior: \'smooth\' });\n              }}\n              className=\"w-full sm:w-auto px-8 py-4 bg-brand-espresso text-brand-cream hover:bg-brand-rust rounded-full font-display text-xs uppercase tracking-[0.2em] font-semibold shadow-lg hover:shadow-xl transition-all duration-300 transform hover:-translate-y-0.5 flex items-center justify-center gap-2 cursor-pointer border border-brand-rust/20\"\n            >\n              Explore Mountain Menu\n              <ArrowRight className=\"w-4 h-4\" />\n            </button>\n\n            <button\n              onClick={() => {\n                setCurrentPage(\'reserve\');\n                window.scrollTo({ top: 0, behavior: \'smooth\' });\n              }}\n              className=\"w-full sm:w-auto px-8 py-4 bg-brand-cream border-2 border-brand-espresso/80 text-brand-espresso hover:bg-brand-espresso hover:text-brand-cream rounded-full font-display text-xs uppercase tracking-[0.2em] font-semibold transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer\"\n            >\n              Reserve Cozy Hearth-Nook\n            </button>\n          </div>\n\n          {/* Micro Banner highlighting key folklore */}\n          <div className=\"mt-14 pt-8 border-t border-brand-cocoa/20 w-full max-w-lg flex items-center justify-center gap-8 text-brand-espresso/70 font-display text-[10px] uppercase tracking-[0.2em]\">\n            <span className=\"flex items-center gap-1.5\"><Leaf className=\"w-3.5 h-3.5 text-brand-pine\" /> Ethically Wild Sourced</span>\n            <span className=\"flex items-center gap-1.5\"><Flame className=\"w-3.5 h-3.5 text-brand-rust\" /> Hearth Wood-Smoked</span>\n          </div>\n\n        </div>\n      </section>\n\n      {/* 2. Cozy Brand Photo Banner & Folklore Snippet */}\n      <section className=\"bg-brand-dark py-20 px-4 text-brand-cream border-y border-brand-rust/35 relative\">\n        <div className=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 items-center\">\n          \n          {/* Custom Styled Coffee/Forest Photo frame */}\n          <div className=\"md:col-span-5 relative group\">\n            <div className=\"absolute inset-0 bg-brand-rust rounded-2xl transform rotate-3 scale-95 opacity-50 group-hover:rotate-1 transition-transform duration-500\" />\n            <div className=\"absolute inset-0 bg-brand-pine rounded-2xl transform -rotate-2 scale-95 opacity-40 group-hover:rotate-0 transition-transform duration-500\" />\n            <div className=\"relative rounded-2xl overflow-hidden aspect-[4/5] shadow-2l border border-brand-cocoa/30\">\n              <img \n                src=\"https://images.unsplash.com/photo-1447078806655-40579c2520d6?q=80&w=700&auto=format&fit=crop\" \n                alt=\"Cozy Himalayan wilderness coffee brewing outdoors over campfire\" \n                className=\"w-full h-full object-cover grayscale-[10%] brightness-90 group-hover:scale-105 transition-transform duration-700\"\n              />\n              <div className=\"absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent flex items-end p-6\">\n                <div>\n                  <span className=\"font-display text-[9px] tracking-widest text-brand-gold uppercase block mb-1\">Our Inspiration</span>\n                  <span className=\"font-serif text-lg text-white block\">A Pinecone on His Nose: The Guardian Bear of Himachal</span>\n                </div>\n              </div>\n            </div>\n          </div>\n\n          <div className=\"md:col-span-7 space-y-6\">\n            <span className=\"font-display text-xs uppercase tracking-[0.25em] text-brand-gold block\">\n              COZY HERITAGE STORY\n            </span>\n            <h2 className=\"font-serif text-3xl md:text-4xl font-bold text-brand-cream-light leading-tight\">\n              {CAFE_STORY.story_title}\n            </h2>\n            <div className=\"h-0.5 w-20 bg-brand-rust\" />\n            <p className=\"font-sans text-sm md:text-base text-brand-cream/80 leading-relaxed font-light\">\n              {CAFE_STORY.paragraphs[0]}\n            </p>\n            <p className=\"font-sans text-sm md:text-base text-brand-cream/80 leading-relaxed font-light\">\n              {CAFE_STORY.paragraphs[1]}\n            </p>\n            \n            <div className=\"pt-4\">\n              <button\n                onClick={() => {\n                  setCurrentPage(\'about\');\n                  window.scrollTo({ top: 0, behavior: \'smooth\' });\n                }}\n                className=\"inline-flex items-center gap-2 text-brand-gold hover:text-brand-cream-light font-display text-[11px] uppercase tracking-widest font-semibold transition-colors duration-300\"\n              >\n                Read Ful Folklore Heritage Story\n                <ArrowRight className=\"w-4 h-4 text-brand-gold\" />\n              </button>\n            </div>\n          </div>\n\n        </div>\n      </section>\n\n      {/* 3. Deep-Dive Seasonal Focus Slider */}\n      <section className=\"bg-brand-cream py-20 px-4\">\n        <div className=\"max-w-6xl mx-auto\">\n          \n          <div className=\"text-center space-y-2 mb-12\">\n            <span className=\"font-display text-xs uppercase tracking-[0.25em] text-brand-rust block\">\n              LIMITED TIME ROTATION\n            </span>\n            <h2 className=\"font-serif text-3xl md:text-4xl font-bold text-brand-espresso\">\n              Current Seasonal Hearth Specials\n            </h2>\n            <p className=\"font-sans text-xs md:text-sm text-brand-cocoa/90 max-w-xl mx-auto\">\n              Prepared daily with wild-harvested pine ingredients and Kotgarh orchard elements. Pull up-close to try them.\n            </p>\n            <div className=\"h-0.5 w-16 bg-brand-rust mx-auto mt-4\" />\n          </div>\n\n          {/* Seasonal Interactive Slider Tabs */}\n          <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-center bg-brand-cream-light rounded-3xl p-6 md:p-10 border border-brand-cocoa/10 shadow-lg\">\n            \n            {/* Spec Card Image Panel */}\n            <div className=\"lg:col-span-5 relative rounded-2xl overflow-hidden aspect-[4/3] md:aspect-square lg:aspect-[4/5] border border-brand-cocoa/10\">\n              <img\n                src={seasonalItems[activeSpecial].image}\n                alt={seasonalItems[activeSpecial].name}\n                className=\"w-full h-full object-cover transition-all duration-500 scale-102\"\n              />\n              <div className=\"absolute top-4 left-4 bg-brand-rust text-brand-cream px-3 py-1 rounded-full text-[9px] uppercase tracking-widest font-display font-semibold shadow-md flex items-center gap-1\">\n                <Sparkles className=\"w-3 h-3 text-brand-gold\" />\n                Active Special\n              </div>\n            </div>\n\n            {/* Spec Details Column */}\n            <div className=\"lg:col-span-7 flex flex-col justify-center space-y-6 lg:pl-6 text-brand-espresso\">\n              \n              <div className=\"flex flex-wrap gap-2\">\n                {seasonalItems[activeSpecial].tags.map((tg, idx) => (\n                  <span key={idx} className=\"px-2.5 py-0.5 bg-brand-pine/10 text-brand-pine text-[10px] font-semibold tracking-wider uppercase rounded\">\n                    {tg}\n                  </span>\n                ))}\n              </div>\n\n              <h3 className=\"font-serif text-3xl md:text-4xl font-bold text-brand-espresso\">\n                {seasonalItems[activeSpecial].name}\n              </h3>\n\n              <div className=\"text-3xl font-display font-light text-brand-rust\">\n                ${seasonalItems[activeSpecial].price.toFixed(2)}\n              </div>\n\n              <p className=\"font-sans text-sm md:text-base text-brand-espresso/80 leading-relaxed font-light\">\n                {seasonalItems[activeSpecial].description}\n              </p>\n\n              {/* Slider Toggle Selectors */}\n              <div className=\"flex gap-4 border-b border-brand-cocoa/20 pb-4\">\n                {seasonalItems.map((item, idx) => (\n                  <button\n                    key={item.id}\n                    onClick={() => setActiveSpecial(idx)}\n                    className={`text-left border-l-2 pl-3 py-1 transition-all ${\n                      activeSpecial === idx \n                        ? \'border-brand-rust font-semibold text-brand-rust\' \n                        : \'border-transparent text-brand-espresso/55 hover:text-brand-espresso hover:border-brand-cocoa/40\'\n                    }`}\n                  >\n                    <span className=\"block text-[10px] uppercase font-display tracking-widest leading-none mb-1\">Spec 0{idx + 1}</span>\n                    <span className=\"font-serif text-sm block leading-none\">{item.name}</span>\n                  </button>\n                ))}\n              </div>\n\n              {/* Action */}\n              <div className=\"flex flex-wrap gap-4 pt-1\">\n                <button\n                  onClick={() => onQuickAdd(seasonalItems[activeSpecial])}\n                  className=\"px-6 py-3 bg-brand-rust hover:bg-brand-espresso text-brand-cream rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 shadow hover:shadow-md cursor-pointer flex items-center gap-2\"\n                >\n                  Add seasonal to Order\n                </button>\n                <button\n                  onClick={() => {\n                    setCurrentPage(\'menu\');\n                    window.scrollTo({ top: 0, behavior: \'smooth\' });\n                  }}\n                  className=\"px-5 py-3 border border-brand-cocoa/40 hover:border-brand-espresso text-brand-espresso hover:bg-brand-espresso/5 rounded-full font-display text-2xs uppercase tracking-widest font-semibold transition-all duration-300 cursor-pointer\"\n                >\n                  View Full Menu\n                </button>\n              </div>\n\n            </div>\n\n          </div>\n\n        </div>\n      </section>\n    </div>\n  );\n};\n"
    }
    diff {
      unified_diff {
